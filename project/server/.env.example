# Server
PORT=5000
NODE_ENV=development

# Database
DB_PATH=./data/medical_registry.db

# Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY_PASSWORD=your-strong-encryption-password-here
ENCRYPTION_KEY_SALT=your-encryption-salt-here
HMAC_KEY_PASSWORD=your-strong-hmac-password-here
HMAC_KEY_SALT=your-hmac-salt-here

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-at-least-256-bits-here
JWT_EXPIRES_IN=15m
REFRESH_SECRET=your-refresh-secret-at-least-256-bits-here
REFRESH_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:3000
